import pardos;
import machine;

-- Sample 3D data (X, Y, Z) where Z is approximately 2*X + 0.5*Y
List[STR] cols = ["X", "Y", "Z"];
List[List[FLOAT]] data = [
    [1.0, 1.0, 2.5],
    [2.0, 1.0, 4.5],
    [3.0, 2.0, 7.0],
    [1.0, 2.0, 3.0],
    [2.0, 2.0, 5.0],
    [3.0, 1.0, 6.5]
];

PARDOS df = pardos.DataFrame(cols, data);
show("Original 3D Data:");
show(df);

-- PCA - Reducing to 2 dimensions
PARDOS pca_model = machine.pca(2);
pca_model.fit(df);

show("Means: ");
show(pca_model.mean_);
show("Explained Variance: ");
show(pca_model.explained_variance_);
show("Components: ");
show(pca_model.components_);

PARDOS reduced_df = pca_model.transform(df);
show("Reduced 2D Data:");
show(reduced_df);
