{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "KAFE",
	"scopeName": "source.kafe",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#constants"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#functions"
		},
		{
			"include": "#libraries"
		},
		{
			"include": "#types"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#punctuation"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.kafe",
				"match": "\\b(if|else|elif|while|for|in|return|import|match|drip|pour|show|len|append|remove|range|FUNC)\\b"
			},
			{
				"name": "keyword.other.cast.kafe",
				"match": "\\b(int|float|str|bool)\\b"
			}]
		},
		"functions": {
			"patterns": [
				{
					"name": "entity.name.function.kafe",
					"match": "(?<=drip\\s+)[a-zA-Z_][a-zA-Z0-9_]*"
				},
				{
					"name": "entity.name.function.call.kafe",
					"match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
				}
			]
		},
		"libraries": {
			"patterns": [{
				"name": "support.class.kafe",
				"match": "\\b(MATH|NUMK|PLOT|FILES|GESHA|PARDOS|MACHINE)\\b"
			}]
		},
		"types": {
			"patterns": [{
				"name": "support.type.kafe",
				"match": "\\b(INT|FLOAT|BOOL|VOID|STR|GESHA|PARDOS|MACHINE|List)\\b"
			}]
		},
		"constants": {
			"patterns": [
				{
					"name": "constant.language.boolean.kafe",
					"match": "\\b(True|False)\\b"
				},
				{
					"name": "constant.numeric.kafe",
					"match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.kafe",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "constant.character.escape.kafe",
							"match": "\\\\."
						}
					]
				},
				{
					"name": "string.quoted.single.kafe",
					"begin": "'",
					"end": "'",
					"patterns": [
						{
							"name": "constant.character.escape.kafe",
							"match": "\\\\."
						}
					]
				}
			]
		},
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-dash.kafe",
					"match": "--.*$"
				},
				{
					"name": "comment.block.kafe",
					"begin": "->",
					"end": "<-"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.logical.kafe",
					"match": "(&&|\\|\\||!)"
				},
				{
					"name": "keyword.operator.comparison.kafe",
					"match": "(==|!=|<=|>=|<|>)"
				},
				{
					"name": "keyword.operator.assignment.kafe",
					"match": "(=|=>)"
				},
				{
					"name": "keyword.operator.arithmetic.kafe",
					"match": "(\\+|\\-|\\*|\\/|%|\\^)"
				}
			]
		},
		"punctuation": {
			"patterns": [
				{
					"name": "punctuation.terminator.statement.kafe",
					"match": ";"
				},
				{
					"name": "punctuation.separator.dictionary.key-value.kafe",
					"match": ":"
				},
				{
					"name": "punctuation.separator.comma.kafe",
					"match": ","
				},
				{
					"name": "punctuation.section.parens.kafe",
					"match": "[()]"
				},
				{
					"name": "punctuation.section.brackets.kafe",
					"match": "[\\[\\]]"
				}
			]
		}
	}
}
